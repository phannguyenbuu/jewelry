# Copy file nay thanh .env va dien thong tin thuc

# --- EasyInvoice ---
EASYINVOICE_API_URL=https://api.easyinvoice.vn
EASYINVOICE_API_USERNAME=API
EASYINVOICE_USERNAME=API
EASYINVOICE_PASSWORD=your_password_here
EASYINVOICE_TAX_CODE=your_tax_code_here
EASYINVOICE_PATTERN=2C26MYY
EASYINVOICE_SERIAL=
EASYINVOICE_BOOK_CODE=

# --- Database ---
# SQLite (mac dinh khi dev local):
# DATABASE_URL=sqlite:///jewelry.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/jewelry_db

# --- Flask ---
FLASK_SECRET_KEY=change_me_to_a_random_string
FLASK_ENV=development
